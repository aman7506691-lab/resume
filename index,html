<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kicks | Premium Shoe Store</title>
    <link rel="stylesheet" href="style.css">
    <!-- Font Awesome for Icons -->
    <link rel="stylesheet" href="style.css"
</head>
<body>
    <script src="script.js"></script>
    <!-- Navbar -->
    <nav>
        <div class="logo">KICKS.</div>
        <ul class="nav-links">
            <li><a href="#">Home</a></li>
            <li><a href="#products">Men</a></li>
            <li><a href="#products">Women</a></li>
            <li><a href="#products">Kids</a></li>
        </ul>
        <div class="nav-icons">
            <i class="fas fa-search"></i>
            <div class="cart-icon" onclick="toggleCart()">
                <i class="fas fa-shopping-cart"></i>
                <span id="cart-count">0</span>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <header class="hero">
        <div class="hero-content">
            <h1>Run Your Own Race</h1>
            <p>Discover the latest collection of performance footwear.</p>
            <a href="#products" class="btn">Shop Now</a>
        </div>
    </header>

    <!-- Products Section -->
    <section id="products" class="container">
        <h2 class="section-title">Trending Now</h2>
        <div class="product-grid" id="product-list">
            <!-- Products will be injected here by JavaScript -->
        </div>
    </section>

    <!-- Simple Cart Overlay -->
    <div class="cart-overlay" id="cart-overlay">
        <div class="cart-box">
            <h3>Your Cart</h3>
            <div id="cart-items">
                <p>Your cart is empty.</p>
            </div>
            <div class="cart-footer">
                <h4>Total: $<span id="cart-total">0</span></h4>
                <button class="btn checkout-btn" onclick="alert('Proceeding to payment gateway...')">Checkout</button>
            </div>
            <button class="close-cart" onclick="toggleCart()">Close</button>
        </div>
    </div>

    <footer>
        <p>&copy; 2023 Kicks Shoe Store. All rights reserved.</p>
    </footer>

    <script src="script.js"></script>
<!-- Code injected by live-server -->
<script>
	// <![CDATA[  <-- For SVG support
